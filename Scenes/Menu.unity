  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Merhaba, ben Bilge Dede.\n\nBug\xFCn seninle olas\u0131 afetler i\xE7in
    bir afet \xE7antas\u0131 haz\u0131rlayaca\u011F\u0131z.\n\n\xC7antan\u0131 haz\u0131rlarken
    can\u0131n\u0131 ve s\xFCreyi takip etmeyi unutma.\nYol \xFCzerindeki hediye
    sand\u0131klar\u0131n\u0131 da ka\xE7\u0131rma. Sand\u0131klardaki sorular\u0131
    do\u011Fru cevaplarsan bonus puan kazanabilirsin.\n\nK\xFC\xE7\xFCk bir ipucu:
    \xC7antana temel ihtiya\xE7 malzemelerini koymal\u0131s\u0131n.\n\nHaydi ba\u015Flayal\u0131m,
    ba\u015Far\u0131lar!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
